---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
---

<html lang="es">
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>Iniciar Sesión - Mundial 2026</title>
        <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"
        ></script>
    </head>
    <body class="bg-gray-50 flex flex-col min-h-screen font-sans">
        <Header />

        <main class="flex-grow flex items-center justify-center p-6 py-32">
            <div
                class="w-full max-w-md bg-white rounded-[2rem] shadow-2xl overflow-hidden border border-gray-100 transform transition-all hover:shadow-blue-500/10"
            >
                <div class="p-10">
                    <div class="text-center mb-10">
                        <img
                            src="/mundial_2026.png"
                            class="w-16 mx-auto mb-6 bg-white p-1 rounded-lg"
                            alt="Mundial 2026"
                        />
                        <h1
                            class="text-3xl font-black uppercase tracking-tighter leading-tight"
                        >
                            Acceso de <span class="text-blue-600">Fan</span>
                        </h1>
                        <p class="text-gray-400 text-sm mt-3 font-medium">
                            Gestiona tus entradas y vive la pasión del torneo
                            más grande del mundo.
                        </p>
                    </div>

                    <form class="space-y-6" onsubmit="event.preventDefault()">
                        <div class="group">
                            <label
                                class="block text-[10px] font-black uppercase tracking-[0.2em] text-gray-400 mb-2 group-focus-within:text-blue-600 transition-colors"
                                >Correo Electrónico</label
                            >
                            <input
                                type="email"
                                placeholder="aficionado@mundial2026.com"
                                class="w-full px-6 py-4 bg-gray-50 border border-gray-100 rounded-2xl focus:outline-none focus:ring-2 focus:ring-blue-600 focus:bg-white transition-all text-sm font-medium shadow-inner"
                            />
                        </div>
                        <div class="group">
                            <label
                                class="block text-[10px] font-black uppercase tracking-[0.2em] text-gray-400 mb-2 group-focus-within:text-blue-600 transition-colors"
                                >Contraseña</label
                            >
                            <input
                                type="password"
                                placeholder="••••••••"
                                class="w-full px-6 py-4 bg-gray-50 border border-gray-100 rounded-2xl focus:outline-none focus:ring-2 focus:ring-blue-600 focus:bg-white transition-all text-sm font-medium shadow-inner"
                            />
                        </div>

                        <div class="flex items-center justify-between text-xs">
                            <label
                                class="flex items-center gap-2 cursor-pointer group"
                            >
                                <input
                                    type="checkbox"
                                    class="w-4 h-4 rounded border-gray-300 text-blue-600 focus:ring-blue-500 transition-all cursor-pointer"
                                />
                                <span
                                    class="text-gray-500 font-bold group-hover:text-gray-900 transition-colors"
                                    >Recordarme</span
                                >
                            </label>
                            <a
                                href="#"
                                class="text-blue-600 font-black uppercase tracking-tighter hover:text-blue-800 transition-colors"
                                >¿Olvidaste tu clave?</a
                            >
                        </div>

                        <button
                            type="submit"
                            class="w-full bg-black text-white font-black uppercase tracking-[0.1em] py-5 rounded-2xl hover:bg-blue-600 transition-all duration-500 transform hover:scale-[1.02] shadow-[0_10px_30px_rgba(0,0,0,0.1)] active:scale-95"
                        >
                            Iniciar Sesión
                        </button>

                        <div class="text-center mt-10">
                            <p
                                class="text-[11px] text-gray-400 font-bold uppercase tracking-widest leading-loose"
                            >
                                ¿Aún no tienes cuenta? <br />
                                <a
                                    href="#"
                                    class="text-blue-600 border-b-2 border-blue-100 hover:border-blue-600 pb-1 transition-all"
                                    >Únete a la comunidad</a
                                >
                            </p>
                        </div>
                    </form>
                </div>
                <div
                    class="bg-gray-50/50 p-6 text-center border-t border-gray-50"
                >
                    <p
                        class="text-[9px] text-gray-400 uppercase font-black tracking-[0.3em]"
                    >
                        Copa del Mundo FIFA 2026
                    </p>
                </div>
            </div>
        </main>

        <Footer />
    </body>
</html>

<style>
    main {
        background-image: radial-gradient(
            circle at 50% 50%,
            #f1f5f9 0%,
            #ffffff 100%
        );
    }
    body {
        opacity: 0;
        animation: pageEntrance 0.8s ease-out forwards;
    }
    @keyframes pageEntrance {
        from {
            opacity: 0;
            transform: translateY(10px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
</style>
